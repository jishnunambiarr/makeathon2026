# Copy to `.env` and fill in (never commit `.env`).
# Get XI_API_KEY from https://elevenlabs.io → Profile / API keys
# Get ELEVEN_AGENT_ID from your Conversational AI agent → Agent ID (starts with agent_...)

PORT=8787
XI_API_KEY=
ELEVEN_AGENT_ID=

# Moodle → Matrix webhook (`POST /webhooks/moodle-to-matrix`)
# Homeserver base URL (no trailing slash is fine)
MATRIX_HOMESERVER=https://matrix.cit.tum.de
MATRIX_ACCESS_TOKEN=
MATRIX_ROOM_ID=
# Optional: path to Playwright storage state (default: ../moodle-playwright/.moodle-storage.json)
# MOODLE_STORAGE_PATH=
# Optional: require Authorization: Bearer <secret> or x-webhook-secret on webhook tools
# MATRIX_WEBHOOK_SECRET=
# MOODLE_MATRIX_WEBHOOK_SECRET=   # legacy alias, same behaviour if MATRIX_WEBHOOK_SECRET unset

# Hackathon demo: Moodle → Matrix without passing URLs from ElevenLabs every time
# Used when POST /webhooks/moodle-to-matrix omits courseUrl / match in the body.
# DEMO_MOODLE_COURSE_URL=https://moodle.tum.de/course/view.php?id=YOUR_ID
# Substring must appear in link text or URL on the course page. Use several, comma-separated:
# DEMO_MOODLE_MATCH=Übungsblatt,Blatt,Übung,pdf

# No Playwright: POST /webhooks/matrix-demo-links posts this list to Matrix (JSON one line)
# DEMO_ASSIGNMENT_LINKS=[{"label":"LA","url":"https://moodle.tum.de/course/view.php?id=123"}]
